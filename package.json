{
  "name": "reticulum-js",
  "version": "0.1.0",
  "description": "Node.js port of the Reticulum Network Stack — wire-compatible with the Python reference implementation",
  "type": "module",
  "main": "src/Reticulum.js",
  "exports": {
    ".": "./src/Reticulum.js",
    "./browser": "./src/browser.js",
    "./identity": "./src/Identity.js",
    "./destination": "./src/Destination.js",
    "./packet": "./src/Packet.js",
    "./link": "./src/Link.js",
    "./transport": "./src/Transport.js",
    "./interfaces/*": "./src/interfaces/*",
    "./crypto": "./src/utils/crypto.js",
    "./storage": "./src/utils/storage.js",
    "./storage-backend": "./src/utils/storage-backend.js"
  },
  "browser": "./src/browser.js",
  "bin": {
    "rnsd": "./bin/rnsd.js",
    "rnstatus": "./bin/rnstatus.js",
    "rnpath": "./bin/rnpath.js"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:interop": "vitest run --config vitest.interop.config.js",
    "serve": "node examples/serve.js",
    "build:browser": "vite build --config vite.browser.config.js",
    "rnsd": "node bin/rnsd.js",
    "rnstatus": "node bin/rnstatus.js",
    "rnpath": "node bin/rnpath.js"
  },
  "keywords": [
    "reticulum",
    "rns",
    "mesh",
    "network",
    "decentralized",
    "cryptography"
  ],
  "author": "Vet Rocket",
  "repository": {
    "type": "git",
    "url": "https://github.com/aerik/reticulum-js.git"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@msgpack/msgpack": "^3.1.3",
    "@noble/curves": "^2.0.1",
    "@noble/hashes": "^2.0.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "vitest": "^4.1.2"
  }
}
